# ─────────────────────────────────────────────────────────────
# Suitconcern — omgevingsvariabelen (kopieer naar .env.local)
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (PostgreSQL) — gedeeld door Prisma én Payload CMS
DATABASE_URL="postgresql://user:password@localhost:5432/suitconcern"

# Auth (NextAuth / Auth.js v5)
# Zet NEXT_PUBLIC_AUTH_ENABLED=true zodra DATABASE_URL + AUTH_SECRET staan; dan
# gebruikt de UI echte login i.p.v. de demo-schakelaar.
NEXT_PUBLIC_AUTH_ENABLED="false"
AUTH_SECRET="genereer-met: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genereer-met: openssl rand -base64 32"
# Seed-admin (npm run db:seed)
SEED_ADMIN_EMAIL="admin@suitconcern.nl"
SEED_ADMIN_PASSWORD="Admin12345!"

# Payload CMS
PAYLOAD_SECRET="genereer-met: openssl rand -base64 32"

# Betalingen (Mollie)
MOLLIE_API_KEY="test_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Transactionele mail (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
MAIL_FROM="Suitconcern <noreply@suitconcern.nl>"
MAIL_ADMIN="orders@suitconcern.nl"

# Zoeken (Algolia)
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
ALGOLIA_ADMIN_KEY=""

# Bestanden (Uploadthing)
UPLOADTHING_TOKEN=""

# Afbeeldingen (Cloudinary — optioneel)
CLOUDINARY_URL=""

# ─────────────────────────────────────────────────────────────
# SRS — voorraad & artikelen voor filiaal Suitconcern (702 verkoop + 704 magazijn)
# ─────────────────────────────────────────────────────────────
# Leesbron catalogus = de SRS stock-snapshot in de (storegents) blobstore.
# Zet dit token om live SRS-data te tonen; zonder token draait de site op mock-data.
STOREGENTS_BLOB_READ_WRITE_TOKEN=""
# Filiaalnummers (defaults 702/704) — alleen overschrijven als SRS wijzigt.
SUITCONCERN_BRANCH_VERKOOP="702"
SUITCONCERN_BRANCH_MAGAZIJN="704"
# Live SOAP GetStock (losse SKU-checks / on-demand verversen) — secret, in Vercel.
SRS_MESSAGE_USER=""
SRS_MESSAGE_PASSWORD=""
SRS_STOCK_BASE_URL="https://ws.srs.nl"
SRS_SOAP_TIMEOUT_MS="20000"

# ─────────────────────────────────────────────────────────────
# FASHN.ai — eigen Suitconcern-modelbeelden (geen SRS-foto's)
# ─────────────────────────────────────────────────────────────
FASHN_API_KEY=""
# Eigen model-"casting" (andere modellen dan elders). Leeg = de ingebouwde default.
FASHN_MODEL_BRIEF=""

# Analytics
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_CLARITY_ID=""
