{
  "name": "suitconcern",
  "version": "0.1.0",
  "private": true,
  "description": "Suitconcern — premium B2B wholesale platform voor gala- en bedrijfskleding",
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "postinstall": "prisma generate",
    "prebuild": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "generate:images": "tsx scripts/generate-images.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@mollie/api-client": "^4.5.0",
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
